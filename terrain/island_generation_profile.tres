paint_street = true

[sub_resource type="Resource" id="Resource_land"]
script = ExtResource("2_rule")

[resource]
script = ExtResource("1_profile")
street_neighbor_offsets = Array[Vector2i]([Vector2i(0, -1), Vector2i(-1, 0), Vector2i(0, 0), Vector2i(1, 0), Vector2i(0, 1)])
