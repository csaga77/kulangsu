[ext_resource type="Script" uid="uid://bc2rtlndfb5gm" path="res://terrain/terrain_generation_profile.gd" id="1_profile"]
[ext_resource type="Script" uid="uid://fhntny4qsoc1" path="res://terrain/terrain_mask_rule.gd" id="2_rule"]

[sub_resource type="Resource" id="Resource_building_mask"]
script = ExtResource("2_rule")
rule_id = &"building_mask"
