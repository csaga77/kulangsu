[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_ferry_caretaker_cond_b"]
script = ExtResource("5_conditional")
line = "You walked someone through the dark. The harbor hears that kind of thing."
journal_step = "Lian noticed you helped in Long Shan Tunnel."
trust_delta = 1
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_b")
priority = 20
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_ferry_caretaker_cond_c"]
script = ExtResource("6_conditions")
fragments_found_min = 3

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_ferry_caretaker_cond_c"]
script = ExtResource("5_conditional")
line = "Three phrases and the plaza is already humming louder. The tower will want to hear them together."
objective = "Carry the recovered phrases to Bagua Tower."
journal_step = "Lian urged you toward the tower now that most phrases are in hand."
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_c")
priority = 30
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_ferry_caretaker_cond_d"]
script = ExtResource("6_conditions")
extra_conditions = {"story_flag_all": ["winter_memory_reveal"]}

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_ferry_caretaker_cond_d"]
script = ExtResource("5_conditional")
line = "A Po has been keeping the house warm enough for your parents to return into something gentler than silence. That kind of care holds longer than people admit. It is part of why this winter hurts the way it does."
journal_step = "Lian tied the winter memory to A Po's care and the parents who keep leaving and returning around it."
save_status = "Lian named care, absence, and winter as the same family story."
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_d")
priority = 32
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_ferry_caretaker_cond_e"]
script = ExtResource("6_conditions")
extra_conditions = {"story_flag_all": ["spring_festival_prepared"]}

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_ferry_caretaker_cond_e"]
script = ExtResource("5_conditional")
line = "This coming festival will be the first one without your grandmother's place still waiting for her. The harbor knows before the house says it aloud."
journal_step = "Lian finally spoke of the first Spring Festival without Grandma as something the whole island is already bracing for."
extra_fields = {"story_event": "spring_festival_resolved"}
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_e")
priority = 35
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_ferry_caretaker_cond_f"]
script = ExtResource("6_conditions")
extra_conditions = {"story_flag_all": ["future_commitment_witnessed"]}

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_ferry_caretaker_cond_f"]
script = ExtResource("5_conditional")
line = "Then let the harbor answer you clearly. A future does not become real only when it is approved. Sometimes it becomes real when you can finally carry it here without apologizing for it."
objective = "If this turning point feels true, let the harbor close the story here."
journal_step = "Lian turned the harbor into the place where an honest future could finally be answered back."
save_status = "Caretaker Lian recognized the harbor as the place where the future-choice route can honestly close."
extra_fields = {"story_event": "future_commitment_end"}
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_f")
priority = 38
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_ferry_caretaker_cond_g"]
script = ExtResource("6_conditions")
required_melody_states = {"festival_melody": "resonant"}

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_ferry_caretaker_cond_g"]
script = ExtResource("5_conditional")
line = "Listen to the ropes now. The harbor kept the melody after the crowd went home. It is not performing anymore, just breathing on its own."
journal_step = "Lian noticed the plaza now carries the restored melody even in the quiet after the festival."
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_g")
priority = 40
once = true

