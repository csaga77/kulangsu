journal_step = "Lian heard the church fragment return and trusts the melody is mending."
trust_delta = 1
conditions = SubResource("ResidentBeatConditionsDefinition_ferry_caretaker_cond_a")
priority = 10
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_ferry_caretaker_cond_b"]
