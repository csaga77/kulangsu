[sub_resource type="Resource" id="ResidentDialogueDefinition_choir_student_lin"]
script = ExtResource("3_dialogue")
ambient_lines = PackedStringArray("I know where the choir should inhale, but not where the phrase lands.", "The bells only sound lonely because they have no voices to answer them.")
dialogue_beats = []
conditional_beats = [SubResource("ResidentConditionalBeatDefinition_choir_student_lin_cond_a"), SubResource("ResidentConditionalBeatDefinition_choir_student_lin_cond_b")]

[resource]
