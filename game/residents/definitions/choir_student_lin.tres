[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_choir_student_lin_cond_a"]
script = ExtResource("5_conditions")
extra_conditions = {"story_flag_all": ["autumn_pressure_named"]}

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_choir_student_lin_cond_a"]
script = ExtResource("4_conditional")
line = "Everyone talks about next year like there is a right note we are all supposed to hit together. I keep worrying I will only find out mine after everyone else has already sung theirs. It helps a little to know the fear is shared, even if that does not make it quieter."
objective = "Carry that shared pressure back into the harbor before you try to answer the future question."
journal_step = "Lin admitted the same pressure is shaping the church side of the island too, which made the fear feel shared instead of private."
save_status = "Choir Student Lin made the autumn pressure feel communal instead of solitary."
extra_fields = {"story_event": "autumn_pressure_shared"}
conditions = SubResource("ResidentBeatConditionsDefinition_choir_student_lin_cond_a")
priority = 20
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_choir_student_lin_cond_b"]
script = ExtResource("5_conditions")
extra_conditions = {"story_flag_all": ["future_commitment_choice"]}

[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_choir_student_lin_cond_b"]
script = ExtResource("4_conditional")
line = "When someone names a future honestly, the choir air changes. It does not make the next note easy. It just makes it sound like it belongs to the singer at last."
journal_step = "Lin heard honesty change the sound of the future, even before it made anything easier."
conditions = SubResource("ResidentBeatConditionsDefinition_choir_student_lin_cond_b")
priority = 30
once = true

[sub_resource type="Resource" id="ResidentSpawnDefinition_choir_student_lin"]
script = ExtResource("7_spawn")
