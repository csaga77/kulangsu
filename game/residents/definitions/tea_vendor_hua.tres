[sub_resource type="Resource" id="ResidentAppearanceDefinition_tea_vendor_hua"]
script = ExtResource("2_appearance")
body_type = "female"
skin = "taupe"
head_path = "head/heads/human/heads_human_female"
hair_path = "hair/bob/hair_relm_short"
