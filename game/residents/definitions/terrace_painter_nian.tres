[sub_resource type="Resource" id="ResidentDialogueDefinition_terrace_painter_nian"]
script = ExtResource("3_dialogue")
ambient_lines = PackedStringArray("The island only starts composing itself when you climb high enough.", "I paint the gaps between landmarks first. That is where the melody hides.")
dialogue_beats = [SubResource("ResidentDialogueBeatDefinition_terrace_painter_nian_a"), SubResource("ResidentDialogueBeatDefinition_terrace_painter_nian_b")]

[resource]
script = ExtResource("1_definition")
