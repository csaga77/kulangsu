ambient_lines = PackedStringArray("The sea wind keeps taking the last note somewhere inland.", "I only need one honest phrase before the harbor can sing along again.")
dialogue_beats = [SubResource("ResidentDialogueBeatDefinition_dock_musician_pei_a"), SubResource("ResidentDialogueBeatDefinition_dock_musician_pei_b"), SubResource("ResidentDialogueBeatDefinition_dock_musician_pei_c")]
conditional_beats = []

[resource]
script = ExtResource("1_definition")
id = "dock_musician_pei"
include_in_catalog = true
display_name = "Dock Musician Pei"
landmark = "Piano Ferry"
role = "Tests small melodic fragments on a weathered travel violin."
routine_note = "Usually perched on a crate where the sea breeze can carry the sound."
melody_hint = "He notices when the harbor chords stop resolving cleanly."
appearance = SubResource("ResidentAppearanceDefinition_dock_musician_pei")
