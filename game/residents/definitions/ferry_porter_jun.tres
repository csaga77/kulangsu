[sub_resource type="Resource" id="ResidentDialogueDefinition_ferry_porter_jun"]
script = ExtResource("3_dialogue")
ambient_lines = PackedStringArray("The carts feel lighter when the harbor has a tune to work with.", "If the ferry ropes start creaking in time again, we will all hear it.")
dialogue_beats = []
conditional_beats = [SubResource("ResidentConditionalBeatDefinition_ferry_porter_jun_cond_a")]

[resource]
script = ExtResource("1_definition")
id = "ferry_porter_jun"
include_in_catalog = true
display_name = "Ferry Porter Jun"
landmark = "Piano Ferry"
role = "Stacks trunks by hand and listens for returning ferries by hull rhythm."
routine_note = "Usually near the cargo lane by the ferry awning."
melody_hint = "He swears the harbor rhythm is missing one dependable downbeat."
appearance = SubResource("ResidentAppearanceDefinition_ferry_porter_jun")
dialogue = SubResource("ResidentDialogueDefinition_ferry_porter_jun")
routine = SubResource("ResidentRoutineDefinition_ferry_porter_jun")
