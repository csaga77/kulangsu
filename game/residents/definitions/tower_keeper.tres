[sub_resource type="Resource" id="ResidentDialogueDefinition_tower_keeper"]
script = ExtResource("3_dialogue")
ambient_lines = PackedStringArray("The higher you climb, the less the island feels like separate errands.", "The tower does not hide answers. It asks whether your clues can stand beside each other.", "Once the phrases agree from up here, the plaza will know where to gather.")
dialogue_beats = [SubResource("ResidentDialogueBeatDefinition_tower_keeper_a"), SubResource("ResidentDialogueBeatDefinition_tower_keeper_b"), SubResource("ResidentDialogueBeatDefinition_tower_keeper_c")]
conditional_beats = [SubResource("ResidentConditionalBeatDefinition_tower_keeper_cond_a"), SubResource("ResidentConditionalBeatDefinition_tower_keeper_cond_b")]

[resource]
script = ExtResource("1_definition")
