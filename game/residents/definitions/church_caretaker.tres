[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_church_caretaker_cond_c"]
script = ExtResource("5_conditional")
line = "Once the school year tightens, the church does not make the memory kinder. It only makes it impossible to avoid. Some grief waits until winter to speak clearly."
journal_step = "Mei named the colder turn of the year as the moment memory stops staying gentle and starts speaking plainly."
extra_fields = {"story_event": "winter_memory_reveal"}
conditions = SubResource("ResidentBeatConditionsDefinition_church_caretaker_cond_c")
priority = 25
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_church_caretaker_cond_d"]
