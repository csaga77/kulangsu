[sub_resource type="Resource" id="ResidentConditionalBeatDefinition_church_caretaker_cond_b"]
script = ExtResource("5_conditional")
line = "Suyin at the tower knows how to read distance. If anyone can line up three separate phrases, it is someone who sees the whole island at once."
journal_step = "Mei endorsed Tower Keeper Suyin as the person who can synthesize the recovered fragments."
conditions = SubResource("ResidentBeatConditionsDefinition_church_caretaker_cond_b")
priority = 20
once = true

[sub_resource type="Resource" id="ResidentBeatConditionsDefinition_church_caretaker_cond_c"]
