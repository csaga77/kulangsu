[sub_resource type="Resource" id="ResidentDialogueDefinition_tunnel_guide"]
script = ExtResource("3_dialogue")
ambient_lines = PackedStringArray("A loud echo is not always the right one. The good routes sound patient.", "If I stop, it means the light ahead no longer feels safe.", "The melody through these tunnels only survives when someone keeps a steady pace.")
dialogue_beats = [SubResource("ResidentDialogueBeatDefinition_tunnel_guide_a"), SubResource("ResidentDialogueBeatDefinition_tunnel_guide_b"), SubResource("ResidentDialogueBeatDefinition_tunnel_guide_c")]
conditional_beats = [SubResource("ResidentConditionalBeatDefinition_tunnel_guide_cond_a"), SubResource("ResidentConditionalBeatDefinition_tunnel_guide_cond_b"), SubResource("ResidentConditionalBeatDefinition_tunnel_guide_cond_c"), SubResource("ResidentConditionalBeatDefinition_tunnel_guide_cond_d")]

[resource]
script = ExtResource("1_definition")
id = "tunnel_guide"
include_in_catalog = true
display_name = "Tunnel Guide Ren"
landmark = "Long Shan Tunnel"
role = "Keeps a calm pace from the southern entrance through to the northern mouth, judging routes by how steady they feel."
routine_note = "Usually moving from the southern entrance through the tunnel to the northern mouth."
melody_hint = "Ren listens for echoes that stay warm instead of the ones that bounce the farthest."
appearance = SubResource("ResidentAppearanceDefinition_tunnel_guide")
dialogue = SubResource("ResidentDialogueDefinition_tunnel_guide")
routine = SubResource("ResidentRoutineDefinition_tunnel_guide")
