ambient_lines = PackedStringArray("Tourists always pause longer at the cards that look musical.", "I think people remember this island with their ears first and their eyes second.")
dialogue_beats = []
conditional_beats = [SubResource("ResidentConditionalBeatDefinition_postcard_seller_an_cond_a"), SubResource("ResidentConditionalBeatDefinition_postcard_seller_an_cond_b")]

[resource]
script = ExtResource("1_definition")
