[gd_scene format=3]

[ext_resource type="Script" path="res://common/cloud_shadow_overlay.gd" id="1_cloud"]

[sub_resource type="Shader" id="Shader_cloud"]
code = "shader_type canvas_item;\nrender_mode unshaded, blend_mul;\n\nuniform vec4 shadow_color : source_color = vec4(0.74, 0.78, 0.82, 0.68);\nuniform float shadow_strength : hint_range(0.0, 1.0) = 0.92;\nuniform float coverage : hint_range(0.0, 1.0) = 0.43;\nuniform float softness : hint_range(0.01, 0.4) = 0.24;\nuniform vec2 noise_scale = vec2(0.00105, 0.00082);\nuniform vec2 detail_scale = vec2(0.00195, 0.00148);\nuniform float drift_speed : hint_range(0.0, 0.2) = 0.06;\nuniform vec2 wind_direction = vec2(0.309017, 0.951057);\nuniform float wind_strength_factor : hint_range(0.0, 1.0) = 0.5111111;\nuniform vec2 world_origin = vec2(0.0, 0.0);\nuniform vec2 visible_world_size = vec2(1024.0, 768.0);\nuniform vec2 drift_offset = vec2(0.0, 0.0);\n\nfloat hash(vec2 p) {\n\treturn fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);\n}\n\nfloat noise(vec2 p) {\n\tvec2 i = floor(p);\n\tvec2 f = fract(p);\n\tvec2 u = f * f * (3.0 - 2.0 * f);\n\treturn mix(\n\t\tmix(hash(i), hash(i + vec2(1.0, 0.0)), u.x),\n\t\tmix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x),\n\t\tu.y\n\t);\n}\n\nfloat fbm(vec2 p) {\n\tfloat value = 0.0;\n\tfloat amplitude = 0.5;\n\tfor (int i = 0; i < 4; i++) {\n\t\tvalue += noise(p) * amplitude;\n\t\tp = p * 2.03 + vec2(11.7, 6.3);\n\t\tamplitude *= 0.5;\n\t}\n\treturn value;\n}\n\nvoid fragment() {\n\tvec2 world_pos = world_origin + UV * visible_world_size + drift_offset;\n\tvec2 broad_uv = world_pos * noise_scale;\n\tvec2 detail_uv = world_pos * detail_scale;\n\tfloat broad = fbm(broad_uv + vec2(2.8, -1.6));\n\tfloat medium = fbm(detail_uv + vec2(-7.2, 4.6));\n\tfloat breakup = fbm(detail_uv * 1.7 + vec2(13.4, -9.1));\n\tfloat body = mix(broad, medium, 0.46);\n\tfloat cloud = smoothstep(coverage - 0.08, coverage + softness, body);\n\tfloat breakup_mask = smoothstep(0.28, 0.84, breakup);\n\tfloat shadow_mask = cloud * mix(0.74, 1.0, breakup_mask);\n\tshadow_mask *= mix(0.9, 1.08, smoothstep(0.24, 0.88, broad));\n\tshadow_mask = clamp(shadow_mask * shadow_strength * shadow_color.a, 0.0, 0.92);\n\tvec3 tint = mix(vec3(1.0), shadow_color.rgb, shadow_mask);\n\tCOLOR = vec4(tint, 1.0);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_cloud"]
shader = SubResource("Shader_cloud")

